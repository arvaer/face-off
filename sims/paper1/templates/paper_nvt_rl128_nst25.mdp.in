integrator                  = md
dt                          = 0.020
nsteps                      = __NSTEPS__

nstlog                      = 1000
nstenergy                   = 1
nstcalcenergy               = 1
nstxout-compressed          = 5000

cutoff-scheme               = Verlet
nstlist                     = 25
verlet-buffer-tolerance     = -1
rlist                       = 1.280

rcoulomb                    = 1.1
rvdw                        = 1.1
coulombtype                 = reaction-field
epsilon-rf                  = 15
vdwtype                     = cutoff
vdw-modifier                = Potential-shift

tcoupl                      = v-rescale
tc-grps                     = System
tau-t                       = 1.0
ref-t                       = 310
nsttcouple                  = 25

pcoupl                      = no

gen-vel                     = yes
gen-temp                    = 310
gen-seed                    = __GEN_SEED__
